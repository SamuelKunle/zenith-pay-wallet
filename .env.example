# Optional — local dev works with ZERO env files: npm install && npm run dev
# Use `.env.local` only when you want to override the defaults below (never commit secrets).

# ─── Client (NEXT_PUBLIC_* is exposed to the browser) ────────────────────────

# Hide IntegrationReadinessBanner on dashboard and wallet-tool modules when branding for production demos.
NEXT_PUBLIC_HIDE_INTEGRATION_CALLOUT=false

# Feature flags (optional) — show "Beta" chips on gated surfaces when true.
NEXT_PUBLIC_FF_INSIGHTS_BETA=false
NEXT_PUBLIC_FF_SCHEDULED_BETA=false

# ─── Server only (never prefix with NEXT_PUBLIC_) ────────────────────────────

# OMIT or leave empty locally — simulated funding on `/fund-wallet` stays available for try-outs.
# Set to true only on staging/production when you must block POST /api/v1/wallet/fund.
ZENITH_DISABLE_SIMULATED_FUNDING=
